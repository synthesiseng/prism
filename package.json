{
  "name": "prism",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Native-first HTML-in-Canvas runtime for treating HTML/CSS as runtime-managed canvas surfaces.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/synsoftworks/prism#readme",
  "bugs": {
    "url": "https://github.com/synsoftworks/prism/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synsoftworks/prism.git"
  },
  "keywords": [
    "canvas",
    "html-in-canvas",
    "html-canvas",
    "runtime"
  ],
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc -b tsconfig.build.json",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
